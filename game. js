const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

let player = {
x:50,
y:300,
width:30,
height:30,
dy:0,
jump:false
};

let gravity = 0.5;

document.addEventListener("keydown", e=>{
if(e.code=="ArrowRight") player.x+=10;
if(e.code=="ArrowLeft") player.x-=10;

if(e.code=="Space" && !player.jump){
player.dy=-10;
player.jump=true;
}
});


function gameLoop(){

ctx.clearRect(0,0,800,400);


// ground
ctx.fillStyle="green";
ctx.fillRect(0,350,800,50);


// player
ctx.fillStyle="red";
ctx.fillRect(
player.x,
player.y,
player.width,
player.height
);


// gravity
player.y += player.dy;
player.dy += gravity;


// ground collision
if(player.y>320){
player.y=320;
player.dy=0;
player.jump=false;
}


requestAnimationFrame(gameLoop);

}

gameLoop();
